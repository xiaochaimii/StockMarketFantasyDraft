# Copy to .streamlit/secrets.toml locally, or paste into the Streamlit
# Community Cloud "Secrets" panel. NEVER commit the real secrets.toml.

# Admin login for the Admin tab.
ADMIN_USERNAME = "choose-a-username"
# Preferred: store only a SHA-256 hash of the password.
#   python -c "import hashlib; print(hashlib.sha256(b'your-password').hexdigest())"
ADMIN_PASSWORD_SHA256 = ""
# Fallback (used only when the hash above is empty):
ADMIN_PASSWORD = ""

# Google Apps Script web-app URL (reactions + votes + Owners tab).
# Rotate by redeploying the Apps Script and pasting the fresh /exec URL here.
SHEETS_URL = ""

# Must match the ADMIN_TOKEN script property set in the Apps Script project.
# Gates the owner-directory (PII) actions.
ADMIN_TOKEN = ""
